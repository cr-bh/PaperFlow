# Gemini API Configuration (用于论文分析)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent
LLM_BEARER_TOKEN=your_bearer_token_here

# Doubao API Configuration (专用于 Auto-Scholar 评分)
# 支持字节跳动火山引擎 API 或其他兼容 OpenAI 格式的 API
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_BEARER_TOKEN=your_doubao_bearer_token_here

# Database Configuration
DATABASE_PATH=data/paperbrain.db
CHROMA_DB_PATH=data/chroma_db

# File Storage
PAPERS_DIR=data/papers
IMAGES_DIR=data/images

# Model Configuration
MODEL_NAME=gemini-pro
EMBEDDING_MODEL=models/embedding-001
TEMPERATURE=0.7
MAX_TOKENS=8192

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# Auto-Scholar Configuration
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,math.OC
ARXIV_MAX_RESULTS=200
SCORE_THRESHOLD=5.0

# 筛选配置
KEYWORD_MIN_MATCHES=2
S2_MIN_CITATIONS=3
S2_MIN_INFLUENTIAL=1
S2_API_KEY=

# S2 API 重试配置
S2_MAX_RETRIES=3
S2_RETRY_DELAY=1.0
S2_REQUEST_INTERVAL=0.3
S2_CACHE_PATH=data/s2_cache.json

# 降级规则关键词（逗号分隔）
S2_FALLBACK_KEYWORDS=large language model,llm,transformer,bert,gpt,attention mechanism,neural network,deep learning,machine learning,reinforcement learning,computer vision,natural language processing,nlp
